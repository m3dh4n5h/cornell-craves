# Supabase project (Settings -> API in the Supabase dashboard)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# The email that gets access to /admin. Must match the account you sign in with.
VITE_ADMIN_EMAIL=your-admin-netid@cornell.edu

# Server-side only. Set via `supabase secrets set`, never in the frontend env.
# RESEND_API_KEY=re_xxxxxxxx
